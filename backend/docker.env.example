MYSQL_USER=oim
MYSQL_PASSWORD=replace_with_strong_database_password
MYSQL_HOST=mysql8
MYSQL_PORT=3306
MYSQL_DB=OMIS
MYSQL_POOL_RECYCLE_SECONDS=3600

JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENVPN_EVENT_SECRET=replace_with_openvpn_event_secret
OPENVPN_CLIENT_CONFIG_ROOT=/data/oim/openvpn-clients
OPENVPN_SSH_KEY_DIR=/data/oim/ssh
OPENVPN_DEFAULT_SSH_KEY_PATH=
OPENVPN_DEFAULT_EASY_RSA_DIR=/etc/openvpn/easy-rsa
OPENVPN_DEFAULT_TLS_CRYPT_KEY_PATH=/etc/openvpn/tls-crypt.key

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace_with_strong_admin_password

AUTO_CREATE_TABLES=false
CORS_ALLOW_ORIGINS=["https://your-domain.example.com","http://your-server-ip"]
