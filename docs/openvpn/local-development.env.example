# OIM Backend - OpenVPN local development config
#
# 用途：
# - 后端运行在本机 127.0.0.1:8000
# - OpenVPN 服务器通过 SSH 反向隧道访问本机后端
#
# 示例隧道：
# ssh -N -R 18080:127.0.0.1:8000 -i ~/.ssh/<ssh-key> root@<openvpn-server-ip>

# 必须与 OpenVPN server.conf 里的 OIM_OPENVPN_EVENT_TOKEN 一致
OPENVPN_EVENT_SECRET=CHANGE_ME_LOCAL_OPENVPN_EVENT_SECRET

# 本地证书归档根目录。证书会按 服务器编码/部门编码/用户名 保存。
OPENVPN_CLIENT_CONFIG_ROOT=./storage/openvpn-clients

# 以下路径为新增OpenVPN服务器时的系统默认值。
# 如果每台服务器路径一致，用户在“新增服务器”中无需手动填写。
OPENVPN_DEFAULT_SSH_KEY_PATH=
OPENVPN_DEFAULT_EASY_RSA_DIR=/etc/openvpn/easy-rsa
OPENVPN_DEFAULT_TLS_CRYPT_KEY_PATH=/etc/openvpn/tls-crypt.key

# 本地开发常用回调地址。该值写入 OpenVPN 服务器配置，不是后端读取项。
OIM_OPENVPN_EVENT_URL=http://127.0.0.1:18080

# OpenVPN服务器编码。必须与系统“OpenVPN服务器管理”的服务器编码一致。
OIM_OPENVPN_SERVER_CODE=CHANGE_ME_SERVER_CODE
