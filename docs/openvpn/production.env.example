# OIM Backend - OpenVPN production config
#
# 用途：
# - 后端部署在线上服务器或容器中
# - OpenVPN 服务器直接访问线上 OIM Backend/API 地址

# 必须与 OpenVPN server.conf 里的 OIM_OPENVPN_EVENT_TOKEN 一致
OPENVPN_EVENT_SECRET=CHANGE_ME_PRODUCTION_OPENVPN_EVENT_SECRET

# 线上证书归档根目录。建议挂载到持久化磁盘。
# 证书会按 服务器编码/部门编码/用户名 保存。
OPENVPN_CLIENT_CONFIG_ROOT=/data/oim/openvpn-clients

# 以下路径为新增OpenVPN服务器时的系统默认值。
# 如果所有OpenVPN服务器采用统一路径，用户无需在页面手动填写。
OPENVPN_SSH_KEY_DIR=/data/oim/ssh
OPENVPN_DEFAULT_SSH_KEY_PATH=
OPENVPN_DEFAULT_EASY_RSA_DIR=/etc/openvpn/easy-rsa
OPENVPN_DEFAULT_TLS_CRYPT_KEY_PATH=/etc/openvpn/tls-crypt.key

# 线上 OpenVPN 服务器回调 OIM 的地址。该值写入 OpenVPN 服务器配置，不是后端读取项。
# 如果 OIM 后端挂在 /api 下，则使用 https://oim.example.com/api
OIM_OPENVPN_EVENT_URL=https://oim.example.com/api

# OpenVPN服务器编码。必须与系统“OpenVPN服务器管理”的服务器编码一致。
OIM_OPENVPN_SERVER_CODE=CHANGE_ME_SERVER_CODE
